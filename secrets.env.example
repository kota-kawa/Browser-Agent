# Copy this file to secrets.env and fill in your API keys.
# This file is used by docker-compose to inject secrets into the FastAPI app.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: override the safety guard model for Groq input checks.
SAFETY_GUARD_MODEL=openai/gpt-oss-safeguard-20b
# Alternatively, you can use the legacy GEMINI_API_KEY variable name if needed.
# GEMINI_API_KEY=

# LLM Monthly API Call Limit (default in code: 1000/month)
LLM_MONTHLY_API_LIMIT=1000
# LLM daily safety budget (all enabled by default even if omitted)
LLM_DAILY_API_LIMIT=300
LLM_DAILY_TOKEN_LIMIT=300000
LLM_DAILY_BUDGET_USD=10
# Cost estimation coefficients used for daily budget accounting
LLM_ESTIMATED_INPUT_USD_PER_1K=0.002
LLM_ESTIMATED_OUTPUT_USD_PER_1K=0.006
# LLM input and output caps (defaults in code)
LLM_INPUT_MAX_CHARS=10000
LLM_MAX_OUTPUT_TOKENS=5000
# Agent timeout and concurrency defaults
AGENT_STEP_TIMEOUT_SECONDS=90
AGENT_RUN_TIMEOUT_SECONDS=900
AGENT_MAX_CONCURRENT_RUNS=1
# IP rate limit defaults
IP_RATE_LIMIT_REQUESTS=120
IP_RATE_LIMIT_WINDOW_SECONDS=60
IP_RATE_LIMIT_TRUST_PROXY_HEADERS=false

# Admin token for protected endpoints:
# /api/agent-relay, /api/reset, /api/pause, /api/resume, /webarena/*, /model_settings
ADMIN_API_TOKEN=

# Allowed domains for custom_task.start_url (comma-separated, suffix match enabled)
# Example: shopping.example.com,gitlab.example.com
WEBARENA_ALLOWED_CUSTOM_TASK_DOMAINS=shopping,shopping_admin,gitlab,forum,wikipedia

# WebArena Credentials
WEBARENA_MAGENTO_EMAIL=emma.lopez@gmail.com
WEBARENA_MAGENTO_PASSWORD=Password.123
WEBARENA_ADMIN_USERNAME=admin
WEBARENA_ADMIN_PASSWORD=admin1234
WEBARENA_GITLAB_USERNAME=root
WEBARENA_GITLAB_PASSWORD=5iveL!fe
WEBARENA_REDDIT_USERNAME=user1
WEBARENA_REDDIT_PASSWORD=password
WEBARENA_MYSQL_PASSWORD=MyPassword

# Telemetry
BROWSER_USE_TELEMETRY_KEY=
